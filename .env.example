# =============================================================================
# Variables d'environnement — copiez ce fichier vers .env.local et remplissez
# les valeurs. Toutes les variables ci-dessous sont réellement lues par le
# code (grep process.env.*).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (base de données + auth + stockage)
# -----------------------------------------------------------------------------
# URL du projet Supabase (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Clé anonyme publique (safe côté client, protégée par RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Clé service-role — SECRÈTE, contourne RLS, serveur uniquement
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Échappatoire build local : "true" autorise un client Supabase placeholder
# en production quand les variables ci-dessus manquent (catalogue vide).
# ALLOW_PLACEHOLDER_SUPABASE=false

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# URL canonique du site (utilisée pour les redirections, emails et la
# validation d'origine CSRF des routes API)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Paiement (Stripe)
# -----------------------------------------------------------------------------
# Clé secrète Stripe (Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_xxx
# Secret de signature du webhook Stripe (Dashboard > Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# -----------------------------------------------------------------------------
# Emails (Brevo)
# -----------------------------------------------------------------------------
# Option 1 (prioritaire) : clé API REST Brevo (Dashboard > SMTP & API > API keys)
BREVO_API_KEY=xkeysib-xxx
# Option 2 (fallback) : relais SMTP (Dashboard > SMTP & API > SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=xxx@smtp-brevo.com
SMTP_PASSWORD=your_brevo_smtp_key
# Expéditeur — DOIT être un expéditeur validé dans Brevo (Senders & Domains),
# sinon les emails sont rejetés ou finissent en spam
EMAIL_FROM=Nuage <commandes@votredomaine.fr>
# Expéditeur des emails marketing (optionnel, défaut = EMAIL_FROM)
# EMAIL_FROM_MARKETING=Nuage <bonjour@votredomaine.fr>
# Adresse de réception du formulaire de contact (/api/contact)
# Par défaut : contact@chichanuage.com
# CONTACT_EMAIL=contact@chichanuage.com

# -----------------------------------------------------------------------------
# Secrets applicatifs
# -----------------------------------------------------------------------------
# Secret Bearer exigé par les endpoints /api/cron/* (Vercel Cron)
# Générer : openssl rand -hex 32
CRON_SECRET=generate_a_long_random_string
# Secret HMAC dédié à la signature des tokens de désinscription newsletter
# (OBLIGATOIRE — aucun fallback). Générer : openssl rand -hex 32
NEWSLETTER_TOKEN_SECRET=generate_another_long_random_string

# -----------------------------------------------------------------------------
# IA / LLM
# -----------------------------------------------------------------------------
# Clé Groq (https://console.groq.com) — chatbot support /api/chat/support
GROQ_API_KEY=gsk_xxx
# Clé OpenRouter (https://openrouter.ai) — traduction produits/avis
OPENROUTER_API_KEY=sk-or-xxx
# Token Hugging Face (https://huggingface.co/settings/tokens) — traduction de secours
HUGGINGFACE_API_TOKEN=hf_xxx

# -----------------------------------------------------------------------------
# Scraper produits (legacy — remplacé par l'API AliExpress ci-dessous)
# -----------------------------------------------------------------------------
# Liste d'URLs (séparées par des virgules) scrappées par le cron /api/cron/scrape
SCRAPE_URLS=

# -----------------------------------------------------------------------------
# AliExpress Open Platform — Dropshipping (DS) API
# https://openservice.aliexpress.com  (programme Dropshipper)
# -----------------------------------------------------------------------------
# App Key (public) — page de l'app dans la console
ALIEXPRESS_APP_KEY=
# App Secret — SECRET, sert à signer chaque requête (ne jamais committer)
ALIEXPRESS_APP_SECRET=
# URL de callback enregistrée dans les réglages de l'app (doit correspondre exactement)
ALIEXPRESS_CALLBACK_URL=https://chichanuage.com/api/aliexpress/callback
# Access token obtenu via `node --env-file=.env.local scripts/aliexpress-auth.mjs <code>`
ALIEXPRESS_ACCESS_TOKEN=
# Refresh token (pour renouveler l'access token avant expiration)
ALIEXPRESS_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Traitement d'images IA (optionnel)
# -----------------------------------------------------------------------------
# URL d'un serveur Stable Diffusion local (laisser vide si non utilisé)
# SD_SERVER_URL=http://localhost:7860
# Token Replicate — utilisé par l'outil sd-processor (voir sd-processor/CLOUD-SETUP.md)
# REPLICATE_API_TOKEN=r8_xxx

# -----------------------------------------------------------------------------
# Google Maps — autocomplétion d'adresse au checkout
# -----------------------------------------------------------------------------
# Clé API Places (https://console.cloud.google.com/google/maps-apis)
# IMPORTANT : restreindre la clé à votre domaine en production
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# -----------------------------------------------------------------------------
# Analytics & tracking (soumis au consentement cookies — RGPD)
# -----------------------------------------------------------------------------
# Google Analytics 4 — Measurement ID (https://analytics.google.com)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Microsoft Clarity — Project ID (https://clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id
# TikTok Pixel — Pixel ID (https://ads.tiktok.com)
NEXT_PUBLIC_TIKTOK_PIXEL_ID=your_tiktok_pixel_id
# Meta Pixel (Facebook) — Pixel ID (https://business.facebook.com)
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id
